{
  "manifest_version": 3,
  "name": "AI SAT Tutor",
  "description": "AI SAT Tutor side panel for StudySpaces questions.",
  "version": "0.0.1",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://studyspaces.com/*",
    "https://*.studyspaces.com/*",
    "https://portal.nextstepsatcoaching.com/*",
    "https://*.portal.nextstepsatcoaching.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI SAT Tutor"
  }
}
